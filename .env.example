# Database — obrigatório. Sem Postgres válido a home (/) retorna 500.
# Ex.: Neon, Supabase ou Postgres local.
DATABASE_URL="postgresql://user:password@host:5432/dash_performance"

# NextAuth — obrigatório. NEXTAUTH_URL deve bater com a URL do navegador (porta inclusa).
# Em produção (Vercel + domínio): https://seudominio.com (sem barra final; mesmo host que o usuário abre).
# Secret: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Vercel Cron — protege GET /api/sync. Gere string aleatória (≥16 chars). Obrigatório em produção se usar cron.
# Ver: https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET=""

# Meta Ads API (https://developers.facebook.com)
META_APP_ID=""
META_APP_SECRET=""

# Google Ads API (https://developers.google.com/google-ads)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_DEVELOPER_TOKEN=""

# Quantos dias de histórico buscar em cada sync Meta/Google (1–730; padrão 90)
ADS_SYNC_HISTORY_DAYS="90"
